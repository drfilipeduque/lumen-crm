# ============================================================
# Lumen CRM — variáveis de ambiente (copie para .env)
# ============================================================

# ----- App -----
NODE_ENV=development

# ----- Banco de dados (PostgreSQL) -----
DATABASE_URL=postgresql://lumen:lumen@localhost:5432/lumen_crm?schema=public

# ----- Redis (cache + filas BullMQ) -----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ----- API (Fastify) -----
API_HOST=0.0.0.0
API_PORT=3333
CORS_ORIGIN=http://localhost:5173

# ----- JWT -----
# Gere segredos fortes em produção (ex.: openssl rand -base64 64)
JWT_ACCESS_SECRET=change-me-please-access-secret
JWT_REFRESH_SECRET=change-me-please-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ----- Web (Vite — variáveis com prefixo VITE_) -----
VITE_API_URL=http://localhost:3333

# ----- WhatsApp — Baileys (não oficial) -----
# Chave AES-256 (hex de 64 chars) usada pra criptografar credenciais Baileys.
# Gere em prod: openssl rand -hex 32
WHATSAPP_ENCRYPTION_KEY=00112233445566778899aabbccddeeff00112233445566778899aabbccddeeff

# ----- WhatsApp — Meta Cloud API (oficial) -----
# App Secret do app Meta usado pra validar HMAC dos webhooks
META_APP_SECRET=
# Versão da Graph API
META_GRAPH_VERSION=v21.0
# Token usado no handshake hub.verify_token (deve coincidir com o configurado na Meta)
META_WEBHOOK_VERIFY_TOKEN=lumen-meta-verify
# URL pública da API (necessária pra Meta enviar webhooks). Em dev use ngrok/cloudflared.
PUBLIC_API_URL=
