// Lumen CRM — Prisma schema
// CRM para clínicas estéticas brasileiras (gestão de leads via WhatsApp)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  ADMIN
  COMMERCIAL
  RECEPTION
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum HistoryAction {
  CREATED
  STAGE_CHANGE
  FIELD_UPDATE
  TAG_ADDED
  TAG_REMOVED
  OWNER_CHANGED
  VALUE_CHANGED
  PRIORITY_CHANGED
  CLOSED_WON
  CLOSED_LOST
  REOPENED
  FILE_UPLOADED
  FILE_DELETED
  REMINDER_CREATED
  REMINDER_COMPLETED
  DESCRIPTION_UPDATED
  TRANSFERRED
}

enum CustomFieldType {
  TEXT
  LONG_TEXT
  NUMBER
  CURRENCY
  DATE
  SELECT
  MULTI_SELECT
  BOOLEAN
  URL
}

enum WhatsAppConnectionType {
  OFFICIAL
  UNOFFICIAL
}

enum WhatsAppConnectionStatus {
  CONNECTED
  DISCONNECTED
  WAITING_QR
  ERROR
}

enum EntryRuleMode {
  AUTO
  MANUAL
}

enum ConversationStatus {
  OPEN
  RESOLVED
}

enum MessageType {
  TEXT
  IMAGE
  AUDIO
  DOCUMENT
  VIDEO
  TEMPLATE
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

enum TemplateCategory {
  MARKETING
  UTILITY
  AUTHENTICATION
}

enum TemplateStatus {
  APPROVED
  PENDING
  REJECTED
}

enum CadenceScope {
  PIPELINE
  STAGE
  OPPORTUNITY
  CONTACT
  GROUP
}

enum CadenceExecutionStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
  FAILED
}

enum WebhookType {
  OUTBOUND
  INBOUND
}

enum AutomationLogType {
  AUTOMATION
  CADENCE
  WEBHOOK
}

enum AutomationLogStatus {
  SUCCESS
  FAILED
  RUNNING
  PARTIAL
}

enum AIProvider {
  CLAUDE
  OPENAI
}

// ============================================================
// USERS & AUTH
// ============================================================

model User {
  id          String    @id @default(cuid())
  name        String
  email       String    @unique
  password    String
  role        UserRole  @default(COMMERCIAL)
  avatar      String?
  phone       String?
  active      Boolean   @default(true)
  lastLogin   DateTime?
  preferences Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  ownedContacts        Contact[]                @relation("ContactOwner")
  ownedOpportunities   Opportunity[]            @relation("OpportunityOwner")
  history              OpportunityHistory[]
  reminders            Reminder[]
  files                File[]
  conversations        Conversation[]           @relation("ConversationAssignee")
  whatsappConnections  UserWhatsAppConnection[]
  sessions             Session[]
  broadcasts           BroadcastCampaign[]      @relation("BroadcastCreator")
  scheduledMessages    ScheduledMessage[]       @relation("ScheduledMessageCreator")

  @@index([role])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  refreshToken String   @unique
  expiresAt    DateTime
  userAgent    String?
  ipAddress    String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// ============================================================
// CONTACTS
// ============================================================

model Contact {
  id        String    @id @default(cuid())
  name      String
  phone     String    @unique
  email     String?
  avatar    String?
  birthDate DateTime?
  cpf       String?
  address   Json?
  notes     String?

  ownerId String?
  owner   User?   @relation("ContactOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  opportunities Opportunity[]
  conversations Conversation[]
  tags          Tag[]          @relation("ContactTags")
  cadenceExecutions CadenceExecution[] @relation("ContactCadenceExecutions")
  broadcastRecipients BroadcastRecipient[] @relation("BroadcastRecipientContact")
  scheduledMessages   ScheduledMessage[]   @relation("ContactScheduledMessages")

  @@index([ownerId])
  @@index([name])
}

// ============================================================
// PIPELINE / FUNIL
// ============================================================

model Pipeline {
  id          String   @id @default(cuid())
  name        String
  description String?
  active      Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stages         Stage[]
  opportunities  Opportunity[]
  customFields   PipelineCustomField[]
  entryRules     ConnectionEntryRule[]

  @@index([order])
}

model Stage {
  id           String  @id @default(cuid())
  pipelineId   String
  name         String
  color        String  @default("#94a3b8")
  order        Int     @default(0)
  isClosedWon  Boolean @default(false)
  isClosedLost Boolean @default(false)

  pipeline       Pipeline              @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  opportunities  Opportunity[]
  historyFrom    OpportunityHistory[]  @relation("HistoryFromStage")
  historyTo      OpportunityHistory[]  @relation("HistoryToStage")
  entryRules     ConnectionEntryRule[]

  @@index([pipelineId, order])
}

// ============================================================
// OPPORTUNITIES
// ============================================================

model Opportunity {
  id          String    @id @default(cuid())
  title       String
  value       Decimal   @default(0) @db.Decimal(12, 2)
  priority    Priority  @default(MEDIUM)
  description String?
  dueDate     DateTime?
  order       Int       @default(0)

  pipelineId String
  stageId    String
  contactId  String
  ownerId    String?

  pipeline Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Restrict)
  stage    Stage    @relation(fields: [stageId], references: [id], onDelete: Restrict)
  contact  Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  owner    User?    @relation("OpportunityOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tags              Tag[]                @relation("OpportunityTags")
  customFieldValues CustomFieldValue[]
  reminders         Reminder[]
  files             File[]
  history           OpportunityHistory[]
  cadenceExecutions CadenceExecution[]
  broadcastRecipients BroadcastRecipient[] @relation("BroadcastRecipientOpportunity")
  scheduledMessages   ScheduledMessage[]   @relation("OpportunityScheduledMessages")

  @@index([pipelineId])
  @@index([stageId])
  @@index([contactId])
  @@index([ownerId])
  @@index([dueDate])
  @@index([createdAt])
  @@index([stageId, order])
}

model OpportunityHistory {
  id            String        @id @default(cuid())
  opportunityId String
  fromStageId   String?
  toStageId     String?
  userId        String?
  action        HistoryAction
  metadata      Json?
  createdAt     DateTime      @default(now())

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  fromStage   Stage?      @relation("HistoryFromStage", fields: [fromStageId], references: [id], onDelete: SetNull)
  toStage     Stage?      @relation("HistoryToStage", fields: [toStageId], references: [id], onDelete: SetNull)
  user        User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([opportunityId, createdAt])
  @@index([action])
  @@index([userId])
  @@index([createdAt])
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#64748b")
  createdAt DateTime @default(now())

  opportunities Opportunity[] @relation("OpportunityTags")
  contacts      Contact[]     @relation("ContactTags")
}

// ============================================================
// CUSTOM FIELDS
// ============================================================

model CustomField {
  id       String          @id @default(cuid())
  name     String
  type     CustomFieldType
  options  Json?
  required Boolean         @default(false)
  active   Boolean         @default(true)
  order    Int             @default(0)

  values    CustomFieldValue[]
  pipelines PipelineCustomField[]

  @@index([active, order])
}

model CustomFieldValue {
  id            String   @id @default(cuid())
  customFieldId String
  opportunityId String
  value         String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customField CustomField @relation(fields: [customFieldId], references: [id], onDelete: Cascade)
  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@unique([customFieldId, opportunityId])
  @@index([opportunityId])
}

model PipelineCustomField {
  pipelineId    String
  customFieldId String
  visible       Boolean @default(true)
  order         Int     @default(0)

  pipeline    Pipeline    @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  customField CustomField @relation(fields: [customFieldId], references: [id], onDelete: Cascade)

  @@id([pipelineId, customFieldId])
  @@index([pipelineId, order])
}

// ============================================================
// REMINDERS & FILES
// ============================================================

model Reminder {
  id            String    @id @default(cuid())
  title         String
  description   String?
  dueAt         DateTime
  completed     Boolean   @default(false)
  completedAt   DateTime?
  snoozedUntil  DateTime?
  notified      Boolean   @default(false)
  notifiedAt    DateTime?
  seenAt        DateTime?
  opportunityId String
  userId        String

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dueAt])
  @@index([userId, completed])
  @@index([opportunityId])
  @@index([completed, notified, dueAt])
}

model File {
  id            String   @id @default(cuid())
  opportunityId String
  userId        String
  name          String
  mimeType      String
  size          Int
  url           String
  createdAt     DateTime @default(now())

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([opportunityId])
}

// ============================================================
// WHATSAPP — CONNECTIONS / CONVERSATIONS / MESSAGES
// ============================================================

model WhatsAppConnection {
  id           String                   @id @default(cuid())
  name         String
  type         WhatsAppConnectionType
  phone        String?
  profileName  String?
  avatar       String?
  status       WhatsAppConnectionStatus @default(DISCONNECTED)
  active       Boolean                  @default(true)

  // OFFICIAL
  wabaId           String?
  phoneNumberId    String?
  accessToken      String?
  qualityTier      String?
  coexistenceMode  Boolean @default(false)

  // UNOFFICIAL
  sessionData String?
  webhookUrl  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         UserWhatsAppConnection[]
  entryRule     ConnectionEntryRule?
  conversations Conversation[]
  templates     Template[]
  cadences      Cadence[]
  cadenceExecutions CadenceExecution[] @relation("CadenceExecutionConnection")
  defaultForRouting WhatsAppRoutingConfig[] @relation("RoutingDefaultConnection")
  broadcasts        BroadcastCampaign[]
  scheduledMessages ScheduledMessage[]  @relation("ConnectionScheduledMessages")

  @@index([status])
  @@index([type])
}

model UserWhatsAppConnection {
  userId       String
  connectionId String

  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  connection WhatsAppConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@id([userId, connectionId])
  @@index([connectionId])
}

model ConnectionEntryRule {
  id           String        @id @default(cuid())
  connectionId String        @unique
  mode         EntryRuleMode @default(MANUAL)
  pipelineId   String
  stageId      String

  connection WhatsAppConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  pipeline   Pipeline           @relation(fields: [pipelineId], references: [id], onDelete: Restrict)
  stage      Stage              @relation(fields: [stageId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Singleton (id sempre = "default") com a estratégia padrão de roteamento
// usada pelas actions de envio de WhatsApp quando não há override no fluxo.
enum WhatsAppRoutingStrategy {
  OFFICIAL_FIRST
  UNOFFICIAL_FIRST
  OFFICIAL_ONLY
  UNOFFICIAL_ONLY
}

model WhatsAppRoutingConfig {
  id                    String                  @id @default("default")
  defaultConnectionId   String?
  defaultStrategy       WhatsAppRoutingStrategy @default(OFFICIAL_FIRST)
  fallbackTemplateId    String?
  autoMarkAsRead        Boolean                 @default(false)
  businessHoursOnly     Boolean                 @default(false)

  defaultConnection  WhatsAppConnection? @relation("RoutingDefaultConnection", fields: [defaultConnectionId], references: [id], onDelete: SetNull)
  fallbackTemplate   Template?           @relation("RoutingFallbackTemplate", fields: [fallbackTemplateId], references: [id], onDelete: SetNull)

  updatedAt DateTime @updatedAt
}

model Conversation {
  id            String             @id @default(cuid())
  contactId     String
  connectionId  String
  assigneeId    String?
  status        ConversationStatus @default(OPEN)
  lastMessageAt DateTime?
  unreadCount   Int                @default(0)
  // JID exato pra envio (ex: "5511...@s.whatsapp.net" ou "...@lid").
  // Quando ausente, monta a partir do phone do contato.
  whatsappJid   String?
  // Janela de 24h da Cloud API: setado pra now+24h a cada msg recebida
  // do contato. Fora dela, só templates podem ser enviados (UNOFFICIAL ignora).
  windowExpiresAt DateTime?

  contact    Contact            @relation(fields: [contactId], references: [id], onDelete: Cascade)
  connection WhatsAppConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  assignee   User?              @relation("ConversationAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  messages   Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([contactId, connectionId])
  @@index([status, lastMessageAt])
  @@index([assigneeId])
  @@index([connectionId])
}

model Message {
  id             String        @id @default(cuid())
  conversationId String
  fromMe         Boolean
  type           MessageType   @default(TEXT)
  content        String?
  mediaUrl       String?
  mediaName      String?
  mediaSize      Int?
  status         MessageStatus @default(SENT)
  externalId     String?
  // Metadados auxiliares: ex.: { templateId, templateName, variables, error }
  metadata       Json?
  sentAt         DateTime?
  deliveredAt    DateTime?
  readAt         DateTime?
  createdAt      DateTime      @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  broadcastRecipients BroadcastRecipient[] @relation("BroadcastRecipientMessage")
  scheduledMessage    ScheduledMessage?    @relation("ScheduledMessageMessage")

  @@index([conversationId, createdAt])
  @@index([externalId])
  @@index([status])
}

// ============================================================
// TEMPLATES & SCRIPTS
// ============================================================

model Template {
  id           String           @id @default(cuid())
  connectionId String
  externalId   String?
  name         String
  category     TemplateCategory
  language     String           @default("pt_BR")
  status       TemplateStatus   @default(PENDING)
  body         String
  variables    Json?
  header       Json?
  footer       String?
  buttons      Json?

  connection WhatsAppConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  fallbackForRouting WhatsAppRoutingConfig[] @relation("RoutingFallbackTemplate")
  broadcasts BroadcastCampaign[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([connectionId, status])
}

model ScriptFolder {
  id    String @id @default(cuid())
  name  String
  order Int    @default(0)

  scripts Script[]

  @@index([order])
}

model Script {
  id        String   @id @default(cuid())
  name      String
  folderId  String?
  content   String
  mediaType String?
  mediaUrl  String?
  variables Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  folder ScriptFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@index([folderId])
}

// ============================================================
// AUTOMATIONS, CADENCES & WEBHOOKS
// ============================================================

model Automation {
  id              String    @id @default(cuid())
  name            String
  active          Boolean   @default(true)
  // triggerType/triggerConfig são denormalizados a partir do nó de trigger do flow,
  // mantidos pra indexação rápida em trigger-matcher (evita parse do JSON).
  triggerType     String
  triggerConfig   Json
  flow            Json
  executionCount  Int       @default(0)
  lastExecutedAt  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  logs AutomationLog[]

  @@index([active, triggerType])
}

model Cadence {
  id           String       @id @default(cuid())
  name         String
  description  String?
  active       Boolean      @default(true)
  // Conexão pré-escolhida (opcional). Quando ausente, a UI/start define no run.
  connectionId String?
  scope        CadenceScope
  // Config dependente do scope:
  //   PIPELINE   -> { pipelineId }
  //   STAGE      -> { pipelineId, stageId }
  //   OPPORTUNITY/CONTACT -> {} (start manual)
  //   GROUP      -> { tagIds?, ownerId?, priority?, valueMin?, valueMax? }
  scopeConfig  Json
  pauseOnReply Boolean      @default(true)
  // Janela comercial; Json[] dia da semana (0=Dom). Default: seg-sex 9-18.
  respectBusinessHours Boolean @default(true)
  businessHoursStart   String  @default("09:00")
  businessHoursEnd     String  @default("18:00")
  businessDays         Int[]   @default([1, 2, 3, 4, 5])
  messages     Json

  connection WhatsAppConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)
  executions CadenceExecution[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, scope])
  @@index([connectionId])
}

model CadenceExecution {
  id              String                 @id @default(cuid())
  cadenceId       String
  // contactId é sempre setado; opportunityId é opcional (escopo CONTACT direto).
  contactId       String
  opportunityId   String?
  // Conexão escolhida no start; pode diferir da default da Cadence.
  connectionId    String?
  currentStep     Int                    @default(0)
  status          CadenceExecutionStatus @default(ACTIVE)
  nextExecutionAt DateTime?
  // Histórico de steps já enviados: [{ stepId, sentAt, messageId? }]
  completedSteps  Json                   @default("[]")
  // Última razão de pausa (ex: "Lead respondeu", "Fora do horário").
  pauseReason     String?

  cadence     Cadence      @relation(fields: [cadenceId], references: [id], onDelete: Cascade)
  contact     Contact      @relation("ContactCadenceExecutions", fields: [contactId], references: [id], onDelete: Cascade)
  opportunity Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  connection  WhatsAppConnection? @relation("CadenceExecutionConnection", fields: [connectionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cadenceId])
  @@index([contactId])
  @@index([opportunityId])
  @@index([connectionId])
  @@index([status, nextExecutionAt])
}

model Webhook {
  id     String      @id @default(cuid())
  type   WebhookType
  name   String
  active Boolean     @default(true)

  // OUTBOUND
  url             String?
  method          String?
  headers         Json?
  events          String[]
  payloadTemplate Json?

  // INBOUND
  uniqueUrl    String? @unique
  authToken    String?
  actionType   String?
  actionConfig Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, active])
}

model AutomationLog {
  id            String              @id @default(cuid())
  type          AutomationLogType
  entityId      String
  // Link forte pra Automation quando type=AUTOMATION (denormalizado pra facilitar joins)
  automationId  String?
  status        AutomationLogStatus
  trigger       String
  // De onde veio: "event:opportunity.created", "manual", "test", "cron"
  triggeredBy   String?
  input         Json?
  output        Json?
  error         String?
  executionTime Int?
  // Cada passo do fluxo: { nodeId, type, status, durationMs, output?, error? }
  steps         Json?
  startedAt     DateTime            @default(now())
  completedAt   DateTime?
  createdAt     DateTime            @default(now())

  automation Automation? @relation(fields: [automationId], references: [id], onDelete: Cascade)

  @@index([type, entityId])
  @@index([createdAt])
  @@index([status])
  @@index([automationId, startedAt])
}

model AIIntegration {
  id            String     @id @default(cuid())
  name          String
  provider      AIProvider
  // API key cifrada (AES-256-GCM, base64). Nunca retornar em rotas.
  apiKey        String
  defaultModel  String
  active        Boolean    @default(true)
  usageCount    Int        @default(0)
  lastUsedAt    DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([active, provider])
}

// ============================================================
// BROADCASTS — disparos em massa via Meta Oficial
// ============================================================

enum BroadcastStatus {
  DRAFT
  SCHEDULED
  SENDING
  PAUSED
  COMPLETED
  FAILED
  CANCELLED
}

enum BroadcastAudienceType {
  CONTACTS
  OPPORTUNITIES
}

enum BroadcastRecipientStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
  SKIPPED
}

model BroadcastCampaign {
  id                String                @id @default(cuid())
  name              String
  description       String?
  connectionId      String
  templateId        String
  templateVariables Json?                 // { "1": "{{contact.name}}", "2": "fixo: Promo" }
  audienceType      BroadcastAudienceType
  audienceFilters   Json                  // depende do audienceType
  audienceSnapshot  Json                  // [contactId, ...] congelado na criação
  intervalSeconds   Int                   @default(30)
  scheduledAt       DateTime?
  status            BroadcastStatus       @default(DRAFT)
  totalRecipients   Int                   @default(0)
  sentCount         Int                   @default(0)
  deliveredCount    Int                   @default(0)
  readCount         Int                   @default(0)
  failedCount       Int                   @default(0)
  pauseReason       String?
  respectBusinessHours Boolean            @default(false)
  createdById       String
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  connection WhatsAppConnection   @relation(fields: [connectionId], references: [id], onDelete: Restrict)
  template   Template             @relation(fields: [templateId], references: [id], onDelete: Restrict)
  createdBy  User                 @relation("BroadcastCreator", fields: [createdById], references: [id], onDelete: Restrict)
  recipients BroadcastRecipient[]

  @@index([status, createdAt])
  @@index([connectionId])
  @@index([createdById])
}

model BroadcastRecipient {
  id            String                   @id @default(cuid())
  campaignId    String
  contactId     String
  opportunityId String?
  phone         String                   // snapshot
  status        BroadcastRecipientStatus @default(PENDING)
  externalId    String?                  // Meta wamid retornado
  messageId     String?                  // Message.id criada no envio
  error         String?
  sentAt        DateTime?
  deliveredAt   DateTime?
  readAt        DateTime?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  campaign    BroadcastCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact     Contact           @relation("BroadcastRecipientContact", fields: [contactId], references: [id], onDelete: Cascade)
  opportunity Opportunity?      @relation("BroadcastRecipientOpportunity", fields: [opportunityId], references: [id], onDelete: SetNull)
  message     Message?          @relation("BroadcastRecipientMessage", fields: [messageId], references: [id], onDelete: SetNull)

  @@unique([campaignId, contactId])
  @@index([campaignId, status])
  @@index([contactId])
  @@index([externalId])
}

// ============================================================
// SCHEDULED MESSAGES — envios individuais agendados
// ============================================================

enum ScheduledMessageStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

enum ScheduledMessageContentType {
  TEXT
  TEMPLATE
  SCRIPT
}

model ScheduledMessage {
  id                String                      @id @default(cuid())
  contactId         String
  opportunityId     String?
  connectionId      String
  scheduledAt       DateTime
  contentType       ScheduledMessageContentType
  content           String                      // texto livre, scriptId ou templateId
  templateVariables Json?
  mediaUrl          String?
  mediaName         String?
  mediaMimeType     String?
  status            ScheduledMessageStatus      @default(PENDING)
  sentAt            DateTime?
  error             String?
  messageId         String?                     @unique
  createdById       String
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt

  contact     Contact            @relation("ContactScheduledMessages", fields: [contactId], references: [id], onDelete: Cascade)
  opportunity Opportunity?       @relation("OpportunityScheduledMessages", fields: [opportunityId], references: [id], onDelete: SetNull)
  connection  WhatsAppConnection @relation("ConnectionScheduledMessages", fields: [connectionId], references: [id], onDelete: Restrict)
  message     Message?           @relation("ScheduledMessageMessage", fields: [messageId], references: [id], onDelete: SetNull)
  createdBy   User               @relation("ScheduledMessageCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([scheduledAt, status])
  @@index([contactId, status])
  @@index([opportunityId, status])
  @@index([connectionId])
}

