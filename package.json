{
  "name": "lumen-crm",
  "version": "0.1.0",
  "private": true,
  "description": "CRM profissional para clínicas estéticas — gestão de leads via WhatsApp",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta --kill-others-on-fail \"pnpm --filter @lumen/api dev\" \"pnpm --filter @lumen/web dev\"",
    "build": "pnpm -r build",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css,html,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css,html,yml,yaml}\"",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @lumen/database generate",
    "db:migrate": "pnpm --filter @lumen/database migrate",
    "db:seed": "pnpm --filter @lumen/database seed",
    "db:studio": "pnpm --filter @lumen/database studio"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0"
  }
}
